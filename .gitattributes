# Shell scripts and the bundled webOS service run on the TV (busybox sh / Linux node).
# They MUST use LF — a CRLF creates a stray \r that breaks busybox sh ("Illegal number").
# Force LF regardless of the developer's core.autocrlf setting.
*.sh text eol=lf
service/service.js text eol=lf
service/autostart.sh text eol=lf
